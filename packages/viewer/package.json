{
  "name": "@cyber/viewer",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/viewer.cjs",
  "module": "./dist/viewer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/viewer.js",
      "require": "./dist/viewer.cjs"
