{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/chainreactors/cyber-ui/packages/agent-protocol/schema/aop.schema.json",
  "title": "Agent Output Protocol Event",
  "type": "object",
  "required": ["type", "ts", "session_id", "agent", "data"],
  "properties": {
    "type": { "type": "string", "minLength": 1 },
    "ts": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "agent": { "type": "string", "minLength": 1 },
    "seq": { "type": "integer", "minimum": 1 },
    "data": { "type": "object" },
    "ext": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "message" } }, "required": ["type"] },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["message_id", "role", "parts"],
            "properties": {
              "message_id": { "type": "string", "minLength": 1 },
              "role": { "type": "string", "minLength": 1 },
              "parts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["type"],
                  "properties": {
                    "type": { "type": "string", "minLength": 1 },
                    "text": { "type": "string" },
                    "image": {
                      "type": "object",
                      "properties": {
                        "path": { "type": "string" },
                        "base64": { "type": "string" },
                        "media_type": { "type": "string" }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "message.delta" } }, "required": ["type"] },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["message_id", "part_index", "part_type", "delta"],
            "properties": {
              "message_id": { "type": "string", "minLength": 1 },
              "part_index": { "type": "integer", "minimum": 0 },
              "part_type": { "type": "string", "minLength": 1 },
              "delta": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "tool.call" } }, "required": ["type"] },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["tool_call_id", "tool_name", "args"],
            "properties": {
              "tool_call_id": { "type": "string", "minLength": 1 },
              "tool_name": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "tool.result" } }, "required": ["type"] },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["tool_call_id", "content"],
            "properties": {
              "tool_call_id": { "type": "string", "minLength": 1 },
              "tool_name": { "type": "string" },
              "is_error": { "type": "boolean" },
              "duration_ms": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": true
          }
        }
      }
    }
  ]
}
